rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.admin == true;
    }

    function isAnonGameClient() {
      // Unity SDK uses Firebase Anonymous Auth
      return isSignedIn()
        && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    function eventShapeOk(d) {
      return d.keys().hasAll([
              'gameId','eventName','playerAnonId',
              'timestamp','platform','appVersion'
            ])
        && d.gameId is string
        && d.eventName is string
        && d.playerAnonId is string
        && d.platform is string
        && d.appVersion is string
        && d.gameId.size() <= 64
        && d.eventName.size() <= 64
        && d.playerAnonId.size() <= 128;
    }

    // ---------- Games ----------
    // Game metadata: only admins write, any signed-in user can read.
    match /games/{gameId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();

      // Events: written by Unity (anonymous auth) OR admin.
      // Read only for admins (panel users).
      match /events/{eventId} {
        allow read: if isAdmin();
        allow create: if (isAnonGameClient() || isAdmin())
                      && eventShapeOk(request.resource.data)
                      && request.resource.data.gameId == gameId;
        allow update, delete: if isAdmin();
      }

      // In-game feedback (rating + free text).
      match /feedback/{feedbackId} {
        allow read: if isAdmin();
        allow create: if (isAnonGameClient() || isAdmin())
                      && request.resource.data.keys().hasAll(['gameId','playerAnonId','timestamp'])
                      && request.resource.data.gameId == gameId;
        allow update, delete: if isAdmin();
      }

      // AI reports — generated by Cloud Functions (admin SDK bypasses rules).
      match /ai_reports/{reportId} {
        allow read: if isAdmin();
        allow write: if false;
      }

      // Aggregated daily stats — generated by Cloud Functions.
      match /stats/{statsId} {
        allow read: if isAdmin();
        allow write: if false;
      }
    }

    // ---------- Market intel ----------
    match /market_intel/{categoryId} {
      allow read: if isAdmin();
      allow write: if false;

      match /{document=**} {
        allow read: if isAdmin();
        allow write: if false;
      }
    }

    match /roadmap_suggestions/{suggestionId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ---------- Users (admin allowlist) ----------
    // Doc id == auth uid. Doc may contain { admin: true, displayName, ... }.
    // Admins are bootstrapped from Cloud Functions / console (not via client write).
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if false;
    }

    // ---------- Default deny ----------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
