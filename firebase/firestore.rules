rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isAnonGameClient() {
      // Unity SDK uses Firebase Anonymous Auth
      return isSignedIn()
        && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    function isGameOwner(gameId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/games/$(gameId))
        && get(/databases/$(database)/documents/games/$(gameId)).data.developerId == request.auth.uid;
    }

    function eventShapeOk(d) {
      return d.keys().hasAll([
              'gameId','eventName','playerAnonId',
              'timestamp','platform','appVersion'
            ])
        && d.gameId is string
        && d.eventName is string
        && d.playerAnonId is string
        && d.platform is string
        && d.appVersion is string
        && d.gameId.size() <= 64
        && d.eventName.size() <= 64
        && d.playerAnonId.size() <= 128;
    }

    // ---------- Developers (B2B müşteri profilleri) ----------
    // Self-service signup: kullanici sadece KENDI profilini olusturabilir.
    // Admin tum profilleri okur/yazar; kullanici sadece kendi profilini.
    match /developers/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());

      // Kendi profilini olusturabilir (self-signup) — uid match + uid field doğru
      // + tier 'indie' veya 'studio' ile baslar (enterprise sadece admin verir)
      allow create: if isAdmin()
        || (isSignedIn()
            && request.auth.uid == uid
            && request.resource.data.uid == uid
            && request.resource.data.email is string
            && (request.resource.data.tier == 'indie'
                || request.resource.data.tier == 'studio'));

      // Update: admin her seyi, developer sadece kendi displayName/studioName
      allow update: if isAdmin()
        || (isSignedIn()
            && request.auth.uid == uid
            && request.resource.data.uid == uid
            && request.resource.data.tier == resource.data.tier);

      allow delete: if isAdmin();
    }

    // ---------- Games ----------
    // Multi-tenant: her oyunun developerId field'i sahibini gosterir.
    // Eski oyunlar (developerId yok) sadece admin tarafindan gorulur (geriye uyumlu).
    match /games/{gameId} {
      allow read: if isAdmin()
        || (isSignedIn()
            && resource.data.keys().hasAny(['developerId'])
            && resource.data.developerId == request.auth.uid);

      // Sadece admin VEYA kendisi sahibi olarak yazabilir.
      allow create: if isAdmin()
        || (isSignedIn() && request.resource.data.developerId == request.auth.uid);
      allow update: if isAdmin()
        || (isSignedIn() && resource.data.developerId == request.auth.uid);
      allow delete: if isAdmin()
        || (isSignedIn() && resource.data.developerId == request.auth.uid);

      // Events: Unity (anonymous) yazar, owner + admin okur.
      match /events/{eventId} {
        allow read: if isAdmin() || isGameOwner(gameId);
        allow create: if (isAnonGameClient() || isAdmin())
                      && eventShapeOk(request.resource.data)
                      && request.resource.data.gameId == gameId;
        allow update, delete: if isAdmin();
      }

      // Feedback: Unity (anonymous) yazar, owner + admin okur.
      match /feedback/{feedbackId} {
        allow read: if isAdmin() || isGameOwner(gameId);
        allow create: if (isAnonGameClient() || isAdmin())
                      && request.resource.data.keys().hasAll(['gameId','playerAnonId','timestamp'])
                      && request.resource.data.gameId == gameId;
        allow update, delete: if isAdmin();
      }

      // AI raporlari — Cloud Functions admin SDK ile yazar (rules bypass).
      match /ai_reports/{reportId} {
        allow read: if isAdmin() || isGameOwner(gameId);
        allow write: if false;
      }

      // Aggregate daily stats — Cloud Functions yazar.
      match /stats/{statsId} {
        allow read: if isAdmin() || isGameOwner(gameId);
        allow write: if false;
      }

      // Sentinel alerts — Cloud Functions yazar, owner okur + 'read' alanini guncelleyebilir.
      match /alerts/{alertId} {
        allow read: if isAdmin() || isGameOwner(gameId);
        allow create: if false;
        allow update: if (isAdmin() || isGameOwner(gameId))
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
        allow delete: if isAdmin();
      }

      // Benchmark snapshots — Cloud Functions yazar.
      match /benchmarks/{benchmarkId} {
        allow read: if isAdmin() || isGameOwner(gameId);
        allow write: if false;
      }

      // Copilot chat history — Cloud Functions yazar, owner okur.
      match /copilot_chats/{chatId} {
        allow read: if isAdmin() || isGameOwner(gameId);
        allow write: if false;
      }

      // Auto-Heal prescriptions — Cloud Functions yazar, owner okur.
      match /auto_heal/{prescriptionId} {
        allow read: if isAdmin() || isGameOwner(gameId);
        allow write: if false;
      }

      // Remote Config (Altare Closed-Loop) — Cloud Functions yazar.
      // OYUN (anonymous) ve OWNER + ADMIN okuyabilir. Oyun bu doc'tan canli
      // ayarlarini ceker (level zorluk, reklam sikligi, IAP vb.).
      match /config/{configId} {
        allow read: if isAnonGameClient() || isGameOwner(gameId) || isAdmin();
        allow write: if false;
      }

      // Player state snapshots — Yigit Ozturk'un onerisi (DB rollback)
      // Oyun yazar (anonymous), owner/admin okur, restore Cloud Function ile.
      match /player_snapshots/{playerAnonId} {
        allow read: if isAnonGameClient() || isGameOwner(gameId) || isAdmin();
        allow write: if false; // Cloud Functions araciligiyla

        match /history/{snapshotId} {
          allow read: if isAnonGameClient() || isGameOwner(gameId) || isAdmin();
          allow write: if false;
        }
      }
    }

    // Industry benchmarks (Cross-Tenant Network Effect)
    // Anonim toplu veri — her signed-in developer okur, Cloud Functions yazar.
    match /industry_benchmarks/{gameType} {
      allow read: if isSignedIn();
      allow write: if false;

      match /daily/{dayKey} {
        allow read: if isSignedIn();
        allow write: if false;
      }
    }

    // ---------- Market intel (Play Store data — okuyan herkes) ----------
    // Public Play Store verisi — her signed-in developer goruntuleyebilir.
    // Yazma sadece Cloud Functions admin SDK uzerinden.
    match /market_intel/{categoryId} {
      allow read: if isSignedIn();
      allow write: if false;

      match /{document=**} {
        allow read: if isSignedIn();
        allow write: if false;
      }
    }

    match /roadmap_suggestions/{suggestionId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ---------- Game concepts (AI Market Strategist cache) ----------
    // Cloud Functions yazar; kullanici sadece kendi konseptlerini okur.
    // Doc id formati: {uid}_{gameType-country} — owner uid prefix'i ile esles.
    match /game_concepts/{conceptId} {
      allow read: if isAdmin()
        || (isSignedIn() && conceptId.matches(request.auth.uid + '_.*'));
      allow write: if false;

      match /history/{historyId} {
        allow read: if isAdmin()
          || (isSignedIn() && conceptId.matches(request.auth.uid + '_.*'));
        allow write: if false;
      }
    }

    // ---------- Users (admin allowlist mirror) ----------
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if false;
    }

    // ---------- Public Discover (login gerektirmez) ----------
    // Cloud Functions (admin SDK) writes; clients NEVER write here directly.
    match /public_market_cache/{cacheId} {
      allow read, write: if false;     // sadece Cloud Functions yazar/okur
    }
    match /public_game_insights/{insightId} {
      allow read, write: if false;
    }
    match /public_rate_limit/{rateId} {
      allow read, write: if false;
    }

    // ---------- Default deny ----------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
